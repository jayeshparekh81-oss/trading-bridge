# ═══════════════════════════════════════════════════════════════════════
# TradeForge — Production Environment Variables
# Copy to .env.production and fill in REAL values.
# ⚠️ NEVER commit .env.production to git!
# ═══════════════════════════════════════════════════════════════════════

# ─── Runtime ────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# ─── Security (GENERATE NEW KEYS FOR PRODUCTION!) ──────────────────────
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=REPLACE_WITH_GENERATED_FERNET_KEY
# openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_RANDOM_32_BYTE_HEX
JWT_ALGORITHM=HS256
WEBHOOK_HMAC_SECRET=REPLACE_WITH_RANDOM_SECRET

# ─── Database (AWS RDS) ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://tradeforge:STRONG_PASSWORD@your-rds-endpoint.ap-south-1.rds.amazonaws.com:5432/tradeforge

# ─── Redis ──────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Celery ─────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── Auth ───────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS ───────────────────────────────────────────────────────────────
CORS_ALLOW_ORIGINS=["https://tradeforge.in","https://www.tradeforge.in"]

# ─── Email (AWS SES) ───────────────────────────────────────────────────
AWS_SES_REGION=ap-south-1
AWS_ACCESS_KEY_ID=REPLACE_WITH_AWS_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_AWS_SECRET
FROM_EMAIL=alerts@tradeforge.in

# ─── Telegram ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=REPLACE_WITH_BOT_TOKEN
TELEGRAM_ENABLED=true

# ─── Brokers ───────────────────────────────────────────────────────────
FYERS_APP_ID=REPLACE_WITH_FYERS_APP_ID
FYERS_APP_SECRET=REPLACE_WITH_FYERS_SECRET
FYERS_REDIRECT_URI=https://api.tradeforge.in/api/brokers/fyers/callback
DHAN_API_BASE_URL=https://api.dhan.co/v2

# ─── Security Policy ──────────────────────────────────────────────────
BRUTE_FORCE_MAX_ATTEMPTS=5
BRUTE_FORCE_LOCK_MINUTES=60
MAX_REQUEST_BODY_SIZE=1048576
TRUSTED_PROXY_IPS=["172.16.0.0/12"]

# ─── Sentry (REQUIRED for production observability) ───────────────────
# Get from https://sentry.io > Project Settings > Client Keys (DSN).
SENTRY_DSN=REPLACE_WITH_PRODUCTION_DSN
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
# CI populates this with the deploying git SHA.
SENTRY_RELEASE=

# ─── TRADETRI feature flags ───────────────────────────────────────────
# Flip to ``true`` post-launch when each subsystem is qualified.
TRADETRI_FF_LIVE_TRADING_ENABLED=false
TRADETRI_FF_MARKETPLACE_ENABLED=false
TRADETRI_AUDIT_RETENTION_DAYS=90

# ─── Dhan broker (live data + intraday backtests) ─────────────────────
DHAN_ACCESS_TOKEN=REPLACE_WITH_DHAN_TOKEN
