# ═══════════════════════════════════════════════════════════════════════
# Trading Bridge Backend — Environment Variables
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ═══════════════════════════════════════════════════════════════════════

# ─── Runtime ────────────────────────────────────────────────────────────
ENVIRONMENT=development               # development | staging | production
DEBUG=true
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR
API_HOST=0.0.0.0
API_PORT=8000

# ─── Security ───────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-with-generated-fernet-key
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-random-32-byte-hex
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
# HMAC secret base for webhook signature verification
WEBHOOK_HMAC_SECRET=replace-with-random-secret

# ─── PostgreSQL ─────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=trading_bridge
POSTGRES_PASSWORD=change-me
POSTGRES_DB=trading_bridge
# Full URL is derived in config.py, but can be overridden here:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/db

# ─── Redis ──────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ─── Celery ─────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── Kill Switch Defaults ───────────────────────────────────────────────
DEFAULT_MAX_DAILY_LOSS_INR=10000
DEFAULT_MAX_DAILY_TRADES=50

# ─── Idempotency ────────────────────────────────────────────────────────
IDEMPOTENCY_TTL_SECONDS=60

# ─── Notifications — AWS SES (Email) ────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=noreply@tradingbridge.in

# ─── Notifications — Telegram ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ─── Fyers (Phase 1 broker) ─────────────────────────────────────────────
# Per-user credentials live in DB; these are platform-level defaults only.
FYERS_APP_ID=
FYERS_REDIRECT_URI=https://tradingbridge.in/api/brokers/fyers/callback

# ─── Observability ──────────────────────────────────────────────────────
PROMETHEUS_METRICS_ENABLED=true
SENTRY_DSN=
