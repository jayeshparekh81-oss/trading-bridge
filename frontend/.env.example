# ═══════════════════════════════════════════════════════════════════════
# TRADETRI Frontend — Environment Variables
# Copy to ``.env.local`` and fill in real values. NEVER commit
# ``.env.local``.
#
# Vars prefixed with ``NEXT_PUBLIC_`` are exposed to the browser
# bundle. Anything without that prefix stays server-side only.
# ═══════════════════════════════════════════════════════════════════════

# ─── Required ──────────────────────────────────────────────────────────
# Backend API base URL. The frontend's ``api`` helper concatenates
# every endpoint path onto this string.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Optional — Observability ─────────────────────────────────────────
# Sentry DSN. Without it the app boots normally but no error
# tracking is reported. Pre-launch must be set in the Vercel
# environment-variable dashboard for the production deployment.
NEXT_PUBLIC_SENTRY_DSN=
# Sentry server-side DSN (same project, server-runtime
# initialisation). Often identical to NEXT_PUBLIC_SENTRY_DSN; kept
# as a separate var so a future split (e.g. server-only project) is
# trivial.
SENTRY_DSN=
# Tags every Sentry event with this label. Falls back to
# ``NODE_ENV`` if unset.
NEXT_PUBLIC_ENVIRONMENT=development
SENTRY_ENVIRONMENT=development
# Sample rate for Sentry tracing (0.0-1.0). 0.1 = 10% of
# transactions traced.
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Build-time only (CI / Vercel) ────────────────────────────────────
# Sentry org auth token used by the build pipeline to upload
# source maps. Do NOT commit. Only set in the build environment.
SENTRY_AUTH_TOKEN=
